<% layout('layouts/boilerplate') -%>
    <style>
        #filters {
            flex-wrap: wrap;
        }

        .filter {
            text-align: center;
            opacity: 0.75;

            &:hover {
                opacity: 1;
                cursor: pointer;
            }

            .para {
                font-size: 0.8rem;
            }
        }

        .tax-info {
            display: none;
        }

        .tax-toggle-input {
            cursor: pointer;
        }

        .tax-toggle {
            height: 3.5rem;
            padding: 1rem;
        }
    </style>
    <div id="filters" class="d-flex align-items-center gap-4 ">
        <div class="filter mt-3">
            <div class=""><i class="fa-solid fa-fire"></i></div>
            <p class="para">Trending</p>
        </div>
        <div class="filter mt-3">
            <div class=""><i class="fa-solid fa-bed"></i></div>
            <p class="para">Room</p>
        </div>
        <div class="filter mt-3">
            <div class=""><i class="fa-solid fa-mountain-city"></i></div>
            <p class="para">Iconic cities</p>
        </div>
        <div class="filter mt-3">
            <div class=""><i class="fa-solid fa-mountain-sun"></i></div>
            <p class="para">Mountains</p>
        </div>
        <div class="filter mt-3">
            <div class=""><i class="fa-brands fa-fort-awesome"></i></div>
            <p class="para">Castles</p>
        </div>
        <div class="filter mt-3">
            <div class=""><i class="fa-solid fa-person-swimming"></i></div>
            <p class="para">Amazing Pools</p>
        </div>
        <div class="filter mt-3">
            <div class=""><i class="fa-solid fa-tents"></i></div>
            <p class="para">Camping</p>
        </div>
        <div class="filter mt-3">
            <div class=""><i class="fa-solid fa-tractor"></i></div>
            <p class="para">Frams</p>
        </div>
        <div class="filter mt-3">
            <div class=""><i class="fa-solid fa-snowflake"></i></div>
            <p class="para">Arctic</p>
        </div>
        <div class="filter mt-3">
            <div class=""><i class="fa-solid fa-building"></i></div>
            <p class="para">Homestay</p>
        </div>
        <div class="filter mt-3">
            <div class=""><i class="fa-solid fa-umbrella-beach"></i></div>
            <p class="para">Beach</p>
        </div>
        <div class="filter mt-3">
            <div class=""><i class="fa-solid fa-taxi"></i></div>
            <p class="para">Taxi Service</p>
        </div>

        <div class="tax-toggle border border-primary rounded-4">
            <div class="form-check-reverse form-switch">
                <input class="form-check-input tax-toggle-input" type="checkbox" role="switch" id="switchCheckDefault">
                <label class="form-check-label" for="switchCheckDefault">Display total after taxes</label>
            </div>
        </div>
    </div>

    <div class="row row-cols-2 row-cols-sm-3 row-cols-md-4 row-cols-lg-5 g-3">
        <%for(let list of allListings) {%>
            <a href="/listings/<%=list._id%>" class="listing-link">
                <div class="card listing-card">
                    <img src="<%=list.image.url%>" class="card-img-top" alt="listing-image">
                    <div class="card-img-overlay">
                        <h6 class="card-title">Guest favourite</h6>
                    </div>
                    <div class="card-body">
                        <p class="card-text">
                            <b><%=list.title%></b>
                            <br>
                            &#8377;<%= list.price ? list.price.toLocaleString("en-IN") : "N/A" %>/Night
                            <i class="tax-info">&nbsp;&nbsp;+18% GST </i>
                        </p>
                    </div>
                </div>
            </a>
            <%}%>
    </div>

    

    <script>
        let taxSwitch = document.getElementById("switchCheckDefault")
        taxSwitch.addEventListener("click", () => {
            let taxInfo = document.getElementsByClassName("tax-info");

            for (info of taxInfo) {
                if (info.style.display != "inline") {

                    info.style.display = "inline";
                }
                else {
                    info.style.display = "none";

                }
            }
        })
    </script>