<% layout('layouts/boilerplate') -%>

    <h2>Create new listing</h2>

    <div class="row mt-3">
        <div class="col-8 offset-2">
            <form action="/listings" method="POST" novalidate class="needs-validation" enctype="multipart/form-data">

                <div class="mb-3">
                    <label for="title" class="form-label">Enter Title :</label>
                    <input
                        name="listing[title]"
                        type="text"
                        class="form-control"
                        id="title"
                        placeholder="enter title"
                        pattern="[A-Za-z\s]+"
                        required>
                    <div class="invalid-feedback">Title required!</div>
                    <div class="valid-feedback">Title Looks Good!</div>
                </div>

                <div class="mb-3">
                    <label for="description" class="form-label">Enter Description :</label>
                    <textarea
                        name="listing[description]"
                        id="description"
                        class="form-control"
                        required></textarea>
                    <div class="invalid-feedback">Please enter a short description!</div>
                    <div class="valid-feedback">Description Looks Catchy!!!</div>
                </div>

                <div class="mb-3">
                    <label for="image" class="form-label">Upload Image :</label>
                    <input
                        name="listing[image]"
                        type="file"
                        id="image"
                        class="form-control"
                        required>
                </div>

                <div class="row">
                    <div class="mb-3 col-md-4">
                        <div class="mb-3">
                            <label for="price" class="form-label">Enter Price :</label>
                            <input
                            name="listing[price]"
                            type="text"
                            class="form-control"
                            id="price"
                            placeholder="1500"
                            required>
                            <div class="invalid-feedback">Price info required!</div>
                        </div>
                    </div>
                    <div class="mb-3 col-md-8">
                        <div class="mb-3">
                            <label for="country" class="form-label">Enter Country :</label>
                            <input
                                name="listing[country]"
                                type="text"
                                class="form-control"
                                id="country"
                                placeholder="India"
                                required>
                            <div class="invalid-feedback">Country required!</div>
                        </div>
                    </div>
                </div>
                <div class="mb-3">
                    <label for="location" class="form-label">Enter Location :</label>
                    <input
                        name="listing[location]"
                        type="text"
                        id="location"
                        class="form-control"
                        placeholder="Jaipur, Rajasthan"
                        required>
                    <div class="invalid-feedback">Location required!</div>
                </div>

                <button class="btn btn-dark add-btn mt-3">Add</button>
            </form>
        </div>
    </div>