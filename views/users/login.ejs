<% layout('layouts/boilerplate') -%>

    <div class="row mt-3">
        <h1 class="col-6 offset-3">Login On WanderLust</h1>
        <div class="col-6 offset-3">
            <form action="/login" method="post" class="needs-validation" novalidate>

                <div class="mb-3">
                    <label class="form-label" for="username">Enter Username : </label><br>
                    <input 
                    class="form-control" 
                    type="text" 
                    id="username" 
                    name="username"
                    required>
                </div>

                <div class="mb-3">
                    <label class="form-label" for="password">Enter Password : </label><br>
                    <input 
                    class="form-control" 
                    type="password" 
                    id="password" 
                    name="password"
                    required>
                </div>

                <button class="btn btn-success">Login</button>
            </form>


        </div>
    </div>